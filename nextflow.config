/*
 * Default settings for the squish test workflows.
 *
 * Memory mode mirrors:
 *   make test-run-all
 *
 * External mode mirrors:
 *   make test-run-all-external
 *
 * Example:
 *   nextflow run main.nf --engine external --samplesheet samples.csv
 */

params {
    samplesheet = 'samples.small.csv'
    outdir = 'output-nextflow'
    engine = 'external'
    bucket = 'auto'
    buckets = 512
    clump_k = 31
    methods = 'alpha,gc,qual,clump'
    make_pdf = true
    container = "stevekm/squish:latest"
    recompress_r1 = true

    run_clumpify      = false
    // reorder=t: reorder reads within clumps by position for better LZ77 compression
    // rcomp=t:   group reverse-complement reads into the same clump (matches squish -clumpRComp)
    // dedupe=f:  no deduplication — keeps output comparable to squish
    clumpify_args     = 'reorder=t rcomp=t dedupe=f'
    clumpify_container = 'community.wave.seqera.io/library/bbmap_pigz:07416fe99b090fa9'//'quay.io/biocontainers/bbmap:39.01--h92535d8_1'
}

executor {
    queueSize = 1
}

process {
    executor = 'local'

    withName: RUN_SQUISH_METHOD {
        container = params.container
        cpus = 1
        memory = '8 GB'
        time = '6 h'
    }

    withName: RUN_CLUMPIFY {
        container = params.clumpify_container
        maxForks = 1
        cpus = 1
        memory = '8 GB'
        time = '6 h'
    }
}

report {
    enabled = true
    file = "${params.outdir}/nextflow-report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/nextflow-trace.txt"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/nextflow-timeline.html"
    overwrite = true
}

profiles {
    docker {
        docker.enabled = true
    }

    // memory {
    //     params.engine = 'memory'
    //     params.outdir = 'output-nextflow-memory'
    // }

    // external {
    //     params.engine = 'external'
    //     params.outdir = 'output-nextflow-external'
    // }

    /*
     * Use this profile when Graphviz/dot is unavailable and PDF generation
     * would make go tool pprof fail.
     */
    no_pdf {
        params.make_pdf = false
    }
}
